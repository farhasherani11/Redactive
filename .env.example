# Copy this file to .env and fill in your real key.
# Never commit the actual .env file — it's already in .gitignore.

# Free tier, no credit card — get a key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your-key-here

# Optional — defaults to llama-3.3-70b-versatile if not set
LLM_MODEL=llama-3.3-70b-versatile
