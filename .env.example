# Copy this file to .env and fill in your real key.
# Never commit the actual .env file — it's already in .gitignore.

# Free tier, no credit card — get a key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your-key-here

# Optional — defaults to llama-3.3-70b-versatile if not set
LLM_MODEL=llama-3.3-70b-versatile

# Required in production. Clients must send this exact value in the
# X-API-Key header to use /analyze. If left blank, auth is disabled —
# fine for local dev, never leave blank on a deployed/public instance.
# Generate any long random string, e.g. via: python -c "import secrets; print(secrets.token_hex(32))"
REDACTIVE_API_KEY=
